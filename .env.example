API_SERVER_KEY=change-me-with-openssl-rand-hex-32

# For Hermes Desktop this is usually not required.
# Set this only if a browser frontend will call Hermes directly.
API_SERVER_CORS_ORIGINS=https://hermes.example.com

HERMES_UID=1000
HERMES_GID=1000

# Main Hermes provider credentials.
# Default config.yaml.example uses OpenRouter as the primary model provider.
OPENROUTER_API_KEY=change-me

# Alternative main-provider examples:
# OPENAI_API_KEY=change-me
# If you use a custom OpenAI-compatible endpoint for Hermes itself,
# put provider/base_url/model into hermes/config.yaml instead.

# TencentDB-Agent-Memory uses its own LLM config for L1/L2/L3 extraction.
# This can point to OpenRouter, OpenAI, Ollama, vLLM, or another
# OpenAI-compatible endpoint independently of the main Hermes model.
MEMORY_TENCENTDB_LLM_API_KEY=change-me

# Default: OpenRouter
MEMORY_TENCENTDB_LLM_BASE_URL=https://openrouter.ai/api/v1
MEMORY_TENCENTDB_LLM_MODEL=openai/gpt-4o-mini

# Alternative memory endpoint examples:
# OpenAI:
# MEMORY_TENCENTDB_LLM_BASE_URL=https://api.openai.com/v1
# MEMORY_TENCENTDB_LLM_MODEL=gpt-4o-mini
#
# Local Ollama:
# MEMORY_TENCENTDB_LLM_API_KEY=ollama
# MEMORY_TENCENTDB_LLM_BASE_URL=http://host.docker.internal:11434/v1
# MEMORY_TENCENTDB_LLM_MODEL=qwen2.5-coder:14b
